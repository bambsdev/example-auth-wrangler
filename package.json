{
  "name": "api-bukukita",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "drizzle-kit migrate --config drizzle.config.local.ts",
    "db:migrate:all": "npm run db:migrate && npm run db:migrate:local",
    "db:push": "drizzle-kit push",
    "db:push:local": "drizzle-kit push --config drizzle.config.local.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@bambsdev/auth": "^1.1.1",
    "@hono/swagger-ui": "^0.5.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
